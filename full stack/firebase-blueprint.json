{
  "entities": {
    "Message": {
      "title": "Chat Message",
      "description": "A message in a chat conversation",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The UID of the user who sent the message"
        },
        "text": {
          "type": "string",
          "description": "The text content of the message"
        },
        "role": {
          "type": "string",
          "enum": ["user", "assistant"],
          "description": "The role of the sender"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the message was created"
        }
      },
      "required": ["uid", "text", "role", "createdAt"]
    },
    "User": {
      "title": "User Profile",
      "description": "The profile of a user",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "name": {
          "type": "string",
          "description": "The user's full name"
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile photo URL"
        }
      },
      "required": ["uid", "email", "name"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages for a specific user"
    }
  }
}
