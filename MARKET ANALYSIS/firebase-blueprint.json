{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User profile photo URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email"]
    },
    "ResearchReport": {
      "title": "Research Report",
      "description": "A market research report generated by the agents",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who generated the report" },
        "topic": { "type": "string", "description": "The research topic" },
        "research": { "type": "object", "description": "Raw research data" },
        "analysis": { "type": "object", "description": "Analyst agent output" },
        "report": { "type": "object", "description": "Final editor report" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["userId", "topic", "report", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/reports/{reportId}": {
      "schema": "ResearchReport",
      "description": "Stored research reports"
    }
  }
}
