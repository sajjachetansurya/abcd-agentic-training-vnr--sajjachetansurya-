rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - createdAt: timestamp
    //
    // Collection: reports
    // Document ID: {reportId}
    // Fields:
    //   - userId: string (required) - Owner of the report
    //   - topic: string (required)
    //   - research: map (required)
    //   - analysis: map (required)
    //   - report: map (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isReportOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string;
    }

    function isValidReport(data) {
      return data.keys().hasAll(['userId', 'topic', 'report', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.topic is string && data.topic.size() < 500;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /reports/{reportId} {
      allow read: if isReportOwner();
      allow create: if isAuthenticated() && isValidReport(request.resource.data);
      allow delete: if isReportOwner();
    }
  }
}
